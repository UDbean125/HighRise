<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="HighRise.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:HighRise.Core.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="20" MaxWidth="920" HorizontalAlignment="Stretch">

            <StackPanel Spacing="2">
                <TextBlock Text="HighRise" Style="{StaticResource TitleLargeTextBlockStyle}" />
                <TextBlock Text="Connect · Merge · Grow" Opacity="0.7" />
            </StackPanel>

            <!-- 1 · Compose -->
            <StackPanel Spacing="8">
                <TextBlock Text="1 · Compose" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBox
                    Header="Subject"
                    Text="{x:Bind ViewModel.Subject, Mode=TwoWay}"
                    PlaceholderText="Quick question about {{Company}}" />
                <ToggleSwitch
                    Header="Body format"
                    IsOn="{x:Bind ViewModel.IsHtml, Mode=TwoWay}"
                    OffContent="Plain text"
                    OnContent="HTML" />
                <TextBox
                    Header="Body"
                    Text="{x:Bind ViewModel.Body, Mode=TwoWay}"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="160"
                    PlaceholderText="Hi {{Name}}, I wanted to reach out about {{Company}}…" />
            </StackPanel>

            <!-- 2 · Import -->
            <StackPanel Spacing="8">
                <TextBlock Text="2 · Import recipients (paste CSV)" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBox
                    x:Name="PasteBox"
                    AcceptsReturn="True"
                    TextWrapping="Wrap"
                    Height="120"
                    PlaceholderText="Name,Email&#x0a;Sam,sam@acme.com" />
                <Button Content="Import" Click="OnImport" />
                <TextBlock Text="{x:Bind ViewModel.ImportSummary, Mode=OneWay}" Opacity="0.8" TextWrapping="Wrap" />
            </StackPanel>

            <!-- 3 · Review -->
            <StackPanel Spacing="8">
                <TextBlock Text="3 · Review" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock Text="{x:Bind ViewModel.ReviewSummary, Mode=OneWay}" />
                <ListView
                    ItemsSource="{x:Bind ViewModel.Previews, Mode=OneWay}"
                    MaxHeight="280"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:MergePreview">
                            <StackPanel Padding="0,6" Spacing="2">
                                <TextBlock Text="{x:Bind Contact.DisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind ResolvedSubject}" Opacity="0.8" FontSize="12" />
                                <TextBlock
                                    Text="{x:Bind BlockingReason}"
                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                    FontSize="12" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- 4 · Send -->
            <StackPanel Spacing="8">
                <TextBlock Text="4 · Send" Style="{StaticResource SubtitleTextBlockStyle}" />
                <ComboBox Header="Provider" x:Name="ProviderBox" SelectedIndex="0" SelectionChanged="OnProviderChanged">
                    <ComboBoxItem Content="Gmail (Google)" />
                    <ComboBoxItem Content="Outlook (Microsoft)" />
                </ComboBox>
                <ComboBox Header="Mode" x:Name="ModeBox" SelectedIndex="0" SelectionChanged="OnModeChanged">
                    <ComboBoxItem Content="Save as drafts" />
                    <ComboBoxItem Content="Send immediately" />
                </ComboBox>
                <Button Content="Go" Click="OnSend" Style="{StaticResource AccentButtonStyle}" />
                <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}" TextWrapping="Wrap" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
